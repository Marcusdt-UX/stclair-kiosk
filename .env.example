# Copy this file to .env and fill in your keys

# Get your free key at https://aisstream.io
VITE_AISSTREAM_API_KEY=your_aisstream_key_here

# Get your free key at https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=your_openweather_key_here

# Dev proxy URL override (optional)
# In dev mode, defaults to http://localhost:2610 automatically.
# In production build, defaults to same-origin (empty).
# Only set this if you need a custom proxy URL.
# VITE_PROXY_URL=http://localhost:2610
